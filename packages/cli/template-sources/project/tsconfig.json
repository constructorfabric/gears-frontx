{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./configs/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/screensets/*": ["./src/screensets/*"],
      "@frontx-test-utils/*": ["./src/__test-utils__/*"],
      "@gears-frontx/state": ["../../../state/src/index.ts"],
      "@gears-frontx/state/*": ["../../../state/src/*"],
      "@gears-frontx/layout": ["../../../layout/src/index.ts"],
      "@gears-frontx/layout/*": ["../../../layout/src/*"],
      "@gears-frontx/api": ["../../../api/src/index.ts"],
      "@gears-frontx/api/*": ["../../../api/src/*"],
      "@gears-frontx/i18n": ["../../../i18n/src/index.ts"],
      "@gears-frontx/i18n/*": ["../../../i18n/src/*"],
      "@gears-frontx/screensets": ["../../../screensets/src/index.ts"],
      "@gears-frontx/screensets/*": ["../../../screensets/src/*"],
      "@gears-frontx/framework": ["../../../framework/src/index.ts"],
      "@gears-frontx/framework/*": ["../../../framework/src/*"],
      "@gears-frontx/react": ["../../../react/src/index.ts"],
      "@gears-frontx/react/*": ["../../../react/src/*"],
      "@gears-frontx/studio": ["../../../studio/src/index.ts"],
      "@gears-frontx/studio/*": ["../../../studio/src/*"],
      "@gears-frontx/cli": ["../../src/index.ts"],
      "@gears-frontx/cli/*": ["../../src/*"]
    }
  },
  "include": ["src", "template-themes.stub.d.ts"]
}
