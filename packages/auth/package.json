{
  "name": "@gears-frontx/auth",
  "version": "0.2.0-alpha.1",
  "description": "Headless authentication contract and types for Gears FrontX SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "8.0.0",
    "typescript": "5.4.2"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "frontx",
    "auth",
    "authentication",
    "authorization",
    "typescript"
  ],
  "author": "Gears FrontX",
  "license": "Apache-2.0"
}
