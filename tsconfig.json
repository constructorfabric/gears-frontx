{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./packages/cli/template-sources/project/configs/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/*": ["./src/app/*"],
      "@/screensets/*": ["./src/screensets/*"],
      "@gears-frontx/state": ["./packages/state/src/index.ts"],
      "@gears-frontx/state/*": ["./packages/state/src/*"],
      "@gears-frontx/layout": ["./packages/layout/src/index.ts"],
      "@gears-frontx/layout/*": ["./packages/layout/src/*"],
      "@gears-frontx/api": ["./packages/api/src/index.ts"],
      "@gears-frontx/api/*": ["./packages/api/src/*"],
      "@gears-frontx/i18n": ["./packages/i18n/src/index.ts"],
      "@gears-frontx/i18n/*": ["./packages/i18n/src/*"],
      "@gears-frontx/framework": ["./packages/framework/src/index.ts"],
      "@gears-frontx/framework/*": ["./packages/framework/src/*"],
      "@gears-frontx/react": ["./packages/react/src/index.ts"],
      "@gears-frontx/react/*": ["./packages/react/src/*"],
      "@gears-frontx/studio": ["./packages/studio/src/index.ts"],
      "@gears-frontx/studio/*": ["./packages/studio/src/*"],
      "@gears-frontx/cli": ["./packages/cli/src/index.ts"],
      "@gears-frontx/cli/*": ["./packages/cli/src/*"]
    }
  },
  "include": ["src", "packages/*/src", "packages/cli/template-sources/layout-custom-uikit"],
  "exclude": ["packages/*/dist", "packages/*/__tests__", "packages/*/src/__tests__", "**/__tests__", "src/mfe_packages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
